{
  "name": "dragonmind-craft",
  "version": "1.0.0",
  "description": "DragonMind Craft - A Minecraft-inspired voxel game by the Chu Collective",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"electron-wait-dev\"",
    "build": "tsc && vite build",
    "build:electron": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "electron": "electron ."
  },
  "dependencies": {
    "three": "^0.160.0",
    "howler": "^2.2.4",
    "simplex-noise": "^4.0.1",
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "@types/howler": "^2.2.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.6",
    "vite-plugin-electron": "^0.15.5"
  },
  "build": {
    "appId": "com.chucollective.dragonmindcraft",
    "productName": "DragonMind Craft",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.games",
      "icon": "assets/icons/icon.png",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
